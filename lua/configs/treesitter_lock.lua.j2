{% if features.prefetch_treesitter == 'true' %}
-- Hard guard: no ensure_installed / :TSInstall / :TSUpdate when parsers are
-- prefetched at gen-time. Complements gen-time strip of install.lua.
local function block()
  vim.notify(
    "[treesitter] prohibited in audit mode: parsers are prefetched only",
    vim.log.levels.WARN
  )
end

local ok, inst = pcall(require, "nvim-treesitter.install")
if ok and type(inst) == "table" then
  inst.install = block
  inst.update = block
  inst.uninstall = function() end
  if type(inst.commands) == "table" then
    inst.commands.install = block
    inst.commands.update = block
    inst.commands.uninstall = function() end
  end
end

local ok2, configs = pcall(require, "nvim-treesitter.configs")
if ok2 and type(configs) == "table" and type(configs.setup) == "function" then
  local orig = configs.setup
  configs.setup = function(opts)
    opts = opts or {}
    opts.ensure_installed = {}
    opts.auto_install = false
    opts.sync_install = false
    return orig(opts)
  end
end

local function kill_cmds()
  for _, c in ipairs({
    "TSInstall",
    "TSInstallSync",
    "TSInstallFromGrammar",
    "TSUpdate",
    "TSUpdateSync",
  }) do
    pcall(vim.api.nvim_del_user_command, c)
  end
end

kill_cmds()
vim.api.nvim_create_autocmd("User", {
  pattern = "LazyDone",
  callback = kill_cmds,
})
-- Plugin may lazy-load later and re-register commands.
vim.api.nvim_create_autocmd("User", {
  pattern = "LazyLoad",
  callback = function(ev)
    if ev.data == "nvim-treesitter" then
      kill_cmds()
    end
  end,
})
{% endif %}
