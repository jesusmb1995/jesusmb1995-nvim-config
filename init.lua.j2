{% set ns = namespace(prefetch=false) -%}
{% for repo in repositories -%}
{% if repo.id == "nvim" and repo.features and "prefetch_plugins" in repo.features -%}
{% set ns.prefetch = true -%}
{% endif -%}
{% endfor -%}
-- Share vim config with neovim
vim.cmd("set runtimepath^=~/.vim runtimepath+=~/.vim/after")
vim.cmd("let &packpath=&runtimepath")

local function source_if_exists(file)
  if vim.fn.filereadable(vim.fn.expand(file)) == 1 then
    vim.cmd("source " .. file)
  end
end

source_if_exists("~/.vimrc")
source_if_exists("~/.vimrc_prog_mapping")

vim.g.base46_cache = vim.fn.stdpath "data" .. "/base46/"
vim.g.mapleader = " "

-- bootstrap lazy: prefer data path (existing runtime install),
-- then config path (pre-fetched bundle or fresh checkout).
-- Clone fallback only when prefetch_plugins is not enabled.
local lazypath = vim.fn.stdpath "data" .. "/lazy/lazy.nvim"
if not vim.uv.fs_stat(lazypath .. "/lua/lazy.lua") then
  lazypath = vim.fn.stdpath "config" .. "/lazy/lazy.nvim"{% if not ns.prefetch %}
  if not vim.uv.fs_stat(lazypath .. "/lua/lazy.lua") then
    local repo = "https://github.com/folke/lazy.nvim.git"
    vim.fn.system { "git", "clone", repo, "--branch=stable", "--depth=1", lazypath }
  end{% endif %}
end

vim.opt.rtp:prepend(lazypath)

local lazy_config = require "configs.lazy"

-- load plugins
local _languages = require "languages"

require("lazy").setup({
  {
    "NvChad/NvChad",
    lazy = false,
    branch = "v2.5",
    import = "nvchad.plugins",
  },

  { import = "plugins" },
}, lazy_config)

require("lazy").setup(GET_INIT_CONFIG(_languages), lazy_config)

-- load theme
dofile(vim.g.base46_cache .. "defaults")
dofile(vim.g.base46_cache .. "statusline")

require "options"
{% if features.treesitter | default('true') != 'true' %}
-- treesitter plugin disabled: rely on neovim's built-in regex syntax engine.
-- NvChad's base46 is treesitter-first and leaves the classic cType/cppStructure/
-- Statement/Comment groups nearly uncolored ("whitish"). Instead of loading a
-- *whole* colorscheme (which repaints Normal/StatusLine/floats and would clobber
-- the NvChad UI), we ONLY repaint the regex-syntax highlight groups that `syntax
-- enable` actually uses. UI chrome (St_*, NvimTree*, NormalFloat, dashboard)
-- does not use these groups, so the NvChad UI is left fully intact -- the theme
-- only shows up inside opened code buffers. These are plain nvim_set_hl calls:
-- 100% fetch-free (no runtime/install fetch), audit-clean.
vim.cmd("syntax enable")
-- NOTE: Neovim bundles a "c" tree-sitter parser (/usr/lib/nvim/parser/c.so) but
-- this config disrupts its auto-discovery, so `vim.treesitter.start()` silently
-- fails on .c. To get native, fetch-free .c highlighting WITHOUT the
-- nvim-treesitter plugin, run these two commands once (e.g. session/keymap):
--   :lua vim.treesitter.language.add("c", { path = "/usr/lib/nvim/parser/c.so" })
--   :lua vim.treesitter.start()
local function _legacy_syntax_hl()
  local set = function(g, o) pcall(vim.api.nvim_set_hl, 0, g, o) end
  set("Comment",    { fg = "#928374", italic = true })
  set("Constant",   { fg = "#d3869b" })
  set("String",     { fg = "#b8bb26" })
  set("Character",  { fg = "#b8bb26" })
  set("Number",     { fg = "#d3869b" })
  set("Boolean",    { fg = "#d3869b" })
  set("Float",      { fg = "#d3869b" })
  set("Identifier", { fg = "#83a598" })
  set("Function",   { fg = "#8ec07c" })
  set("Statement",  { fg = "#fb4934" })
  set("Keyword",    { fg = "#fb4934" })
  set("Conditional",{ fg = "#fb4934" })
  set("Repeat",     { fg = "#fb4934" })
  set("Label",      { fg = "#fb4934" })
  set("Operator",   { fg = "#ebdbb2" })
  set("Type",       { fg = "#fabd2f" })
  set("Structure",  { fg = "#fabd2f" })
  set("StorageClass", { fg = "#fabd2f" })
  set("PreProc",    { fg = "#fe8019" })
  set("Include",    { fg = "#fe8019" })
  set("Define",     { fg = "#fe8019" })
  set("Macro",      { fg = "#fe8019" })
  set("Special",    { fg = "#fe8019" })
  set("SpecialChar",{ fg = "#fe8019" })
  set("Todo",       { fg = "#fabd2f", bold = true })
  set("Underlined", { fg = "#83a598", underline = true })
  set("Error",      { fg = "#fb4934", bold = true })
  set("Debug",      { fg = "#928374" })
end
_legacy_syntax_hl()
-- re-apply after colorscheme loads / on new code buffers, in case a plugin
-- reset groups (no-op for non-code buffers, so UI stays untouched).
vim.api.nvim_create_autocmd({ "FileType", "ColorScheme" }, {
  pattern = "*",
  callback = function()
    if vim.api.nvim_get_option_value("buftype", { buf = 0 }) ~= "" then return end
    _legacy_syntax_hl()
  end,
})
{% endif %}
{% if features.prefetch_treesitter == 'true' %}
pcall(require, "configs.treesitter_bootstrap")
{% endif %}
require "nvchad.autocmds"
{% if features.treesitter | default('true') != 'true' %}
-- NvChad's autocmd group (NvFilePost) fires pcall(vim.treesitter.start) on every
-- buffer; with the plugin off it has no parser and silently no-ops, so drop the
-- group entirely. Done after require "nvchad.autocmds" (which created it).
pcall(vim.api.nvim_del_augroup_by_name, "NvFilePost")
{% endif %}

vim.schedule(function()
  require "mappings"
end)

vim.wo.relativenumber=true

-- Register workspace in tmux warm daemon if .was_agent marker exists
function _G.register_warm_workspace()
  local root = vim.fn.getcwd()
  if vim.fn.filereadable(root .. "/.was_agent") == 0 then return end

  local ws_file = "/tmp/tmux_warm_agent_workspaces.json"
  local workspaces = {}

  local f = io.open(ws_file, "r")
  if f then
    local ok, decoded = pcall(vim.json.decode, f:read("*a"))
    f:close()
    if ok and type(decoded) == "table" then
      workspaces = decoded
    end
  end

  for _, path in ipairs(workspaces) do
    if path == root then return end
  end

  table.insert(workspaces, root)
  f = io.open(ws_file, "w")
  if f then
    f:write(vim.json.encode(workspaces))
    f:close()
  end

  local pid = io.open("/tmp/tmux_warm_daemon.pid", "r")
  if pid then
    local daemon_pid = pid:read("*l")
    pid:close()
    if daemon_pid then
      os.execute("kill -USR1 " .. daemon_pid .. " 2>/dev/null")
    end
  end
end

-- Ensure the tmux warm daemon is running. Neovim can be launched directly
-- (i3 $mod+g -> `st-zsh -e nvim`) without a shell that sources
-- .zshrc/.bashrc, so the daemon may not have been started. Bring it up here
-- so <C-l> can always attach to the pre-warmed agent@<hash> session.
function _G.ensure_warm_daemon()
  local pid_file = "/tmp/tmux_warm_daemon.pid"
  local running = false
  local f = io.open(pid_file, "r")
  if f then
    local pid = f:read("*l")
    f:close()
    if pid and pid ~= "" then
      if os.execute("kill -0 " .. pid .. " 2>/dev/null") == 0 then
        running = true
      end
    end
  end
  if not running then
    local daemon = vim.fn.expand("~") .. "/.tmux_warm_daemon/tmux_warm_daemon"
    if vim.fn.executable(daemon) == 1 then
      vim.fn.jobstart({ daemon }, { detach = true, stdout = "/dev/null", stderr = "/dev/null" })
    end
  end
end

vim.api.nvim_create_autocmd("VimEnter", {
  callback = function()
    ensure_warm_daemon()
    register_warm_workspace()
  end,
})
vim.api.nvim_create_autocmd("DirChanged", {
  callback = register_warm_workspace,
})
