{% if not system_tools.jj %}
return {
  'akinsho/git-conflict.nvim',
  enabled = function()
    return vim.env.NVIM_MINIMAL == nil
  end,
  version = "*",
  config = true,
  cmd = { "GitConflictListQf", "GitConflictRefresh" }
}
{% else %}
-- jj mode: git-conflict disabled (jj has first-class conflicts; use :J resolve).
return {}
{% endif %}
