{% if features.prefetch_treesitter == 'true' %}
-- Compile vendored grammar source into stdpath("data")/parsers and register
-- via vim.treesitter.language.add. No network; source arrives prefetched.
local function bootstrap_parsers()
  local src_root = vim.fn.stdpath("config") .. "/grammars"
  local out_dir = vim.fn.stdpath("data") .. "/parsers"
  vim.fn.mkdir(out_dir, "p")
  local ts_inc = src_root .. "/.ts_include"
  local ok, langs = pcall(require, "languages")

  for lang, on in pairs(ok and langs or {}) do
    if not on then goto continue end
    local src_dir = src_root .. "/" .. lang
    if vim.fn.isdirectory(src_dir) ~= 1 then goto continue end

    local so = out_dir .. "/" .. lang .. ".so"
    local files = {}
    local has_cxx = false
    for _, name in ipairs({ "parser.c", "scanner.c", "scanner.cc", "abi.cc" }) do
      local path = src_dir .. "/src/" .. name
      if vim.fn.filereadable(path) == 1 then
        table.insert(files, path)
        if name:match("%.cc$") then
          has_cxx = true
        end
      end
    end
    if #files == 0 then goto continue end

    local need_build = vim.fn.filereadable(so) == 0
    if not need_build then
      local so_mtime = vim.fn.getftime(so)
      for _, f in ipairs(files) do
        if vim.fn.getftime(f) > so_mtime then
          need_build = true
          break
        end
      end
    end

    if need_build then
      local compiler = has_cxx and "clang++" or "clang"
      local std = has_cxx and "-std=c++17" or "-std=c11"
      local cmd = {
        compiler, "-O2", "-shared", "-fPIC", std,
        "-DTREE_SITTER_ABI_VERSION=15",
        "-I" .. ts_inc,
        "-I" .. src_dir .. "/src",
      }
      for _, f in ipairs(files) do
        table.insert(cmd, f)
      end
      table.insert(cmd, "-o")
      table.insert(cmd, so)

      local result = vim.fn.system(cmd)
      if vim.v.shell_error ~= 0 then
        pcall(vim.fn.delete, so)
        vim.notify(
          "[treesitter] compile failed for " .. lang .. ": " .. tostring(result),
          vim.log.levels.WARN
        )
        goto continue
      end
    end

    if vim.fn.filereadable(so) == 1 then
      pcall(vim.treesitter.language.add, lang, { path = so })
    end
    ::continue::
  end
end
bootstrap_parsers()
{% endif %}
