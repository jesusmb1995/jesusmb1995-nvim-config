{# External IDE editors. Gated on features.cursor_ide / features.clion (default
   off). NOTE: this is NOT ai_tools.cursor, which is the Cursor *CLI* agent tool.
   When no IDE feature is enabled this file renders empty and is pruned by the
   nvim post-render hook (dead-lua cleanup); mappings/init.lua requires it via
   pcall so a missing file is harmless. #}
{%- if features.cursor_ide | default('') == 'true' %}
-- Cursor IDE: open folder + file, start new chat
local map = vim.keymap.set
map("n", "<leader><C-S-l>", function()
  local cwd = vim.fn.getcwd()
  local current_file = vim.fn.expand "%:p"
  local system_command = "cursor "
    .. cwd
    .. " --goto "
    .. current_file
    .. ":"
    .. vim.fn.line "."
    .. " --command workbench.action.chat.newChat 2> /dev/null & disown || true"
  vim.fn.system(system_command)
end, { desc = "Open folder and file in Cursor, start new chat" })
{% endif %}
{%- if features.clion | default('') == 'true' %}
-- Open current file in CLion
vim.api.nvim_create_user_command("Intellij", function()
  local file_path = vim.fn.expand "%:p"
  local line_number = vim.fn.line "."
  local column_number = vim.fn.col "."
  local project_root = vim.fn.systemlist("git rev-parse --show-toplevel")[1]
  if vim.v.shell_error ~= 0 then project_root = vim.fn.getcwd() end
  local command = string.format(
    "clion --project %s --line %d --column %d %s",
    vim.fn.shellescape(project_root), line_number, column_number,
    vim.fn.shellescape(file_path))
  vim.fn.jobstart(command, {
    detach = true,
    on_stderr = function(_, data)
      if data and #data > 1 then
        vim.notify("Error opening CLion: " .. vim.inspect(data), vim.log.levels.ERROR)
      end
    end,
  })
  vim.notify("Opening file in CLion...", vim.log.levels.INFO)
end, {})
vim.keymap.set("n", "<leader>ic", ":Intellij<CR>", { noremap = true, silent = true, desc = "Open in CLion" })
{% endif %}
