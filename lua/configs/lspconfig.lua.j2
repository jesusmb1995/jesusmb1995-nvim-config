-- load defaults i.e lua_lsp
require("nvchad.configs.lspconfig").defaults()

{% if languages.jinja %}
vim.filetype.add({ extension = { j2 = "jinja" } })
{% endif %}

-- EXAMPLE
local servers = {
{% if languages.cpp %}
  "clangd",        -- C/C++
{% endif %}
{% if languages.python %}
  "pyright",       -- Python
{% endif %}
{% if languages.rust %}
  "rust_analyzer", -- Rust
{% endif %}
{% if languages.javascript or languages.typescript %}
  "ts_ls",         -- Javascript and Typescript
{% endif %}
{% if languages.yaml %}
  "yamlls",        -- YAML
{% endif %}
{% if languages.json %}
  "jsonls",        -- JSON
{% endif %}
{% if languages.html %}
  "html",
{% endif %}
{% if languages.css %}
  "cssls",
{% endif %}
{% if languages.bash %}
  "bashls",        -- Bash
{% endif %}
{% if languages.cmake %}
  "cmake",
{% endif %}
{% if languages.toml %}
  "taplo",         -- Toml (Rust)
{% endif %}
{% if languages.markdown %}
  "marksman",      -- Markdown
{% endif %}
{% if languages.docker %}
  "dockerls",
{% endif %}
{% if languages.jsonnet %}
  "jsonnet-language-server",
{% endif %}
{% if languages.jinja %}
  "jinja-lsp",
{% endif %}
{% if languages.amber %}
  "amber-lsp",
{% endif %}

  -- Below to be installed by hand on :Mason. Go to line and do "i" key to install.
  -- Not installed automatically!!

  -- linters
  --"cpplint",
  --"pylint",
  --"yamllint",
  --"biomejs"
  --"standardjs"
  --"shellcheck"
  --"amber-lsp"
  --"jinja-lsp"

  -- formatters
  --"clang-format", -- C/C++ (but also java and js)
  --"rustfmt",
  --"black", -- python
  --"yamlfmt",
  --"prettier"
  --"cmakelang"
  --"beautysh"
}
local nvlsp = require "nvchad.configs.lspconfig"

local function with_defaults(opts)
  return vim.tbl_deep_extend("force", {
    on_attach = nvlsp.on_attach,
    on_init = nvlsp.on_init,
    capabilities = nvlsp.capabilities,
  }, opts or {})
end

-- Use vim.lsp.config (Neovim 0.11+). Do not require("lspconfig") to avoid deprecation.
{% if languages.jinja %}
vim.lsp.config("jinja_lsp", with_defaults {
  filetypes = { "jinja", "njk", "j2" }, -- Add support for .njk files
})
vim.lsp.enable "jinja_lsp"

{% endif %}
for _, lsp in ipairs(servers) do
  vim.lsp.config(lsp, with_defaults())
  vim.lsp.enable(lsp)
end

